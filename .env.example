NEXT_PUBLIC_SITE_URL=https://elitecourts.com.pk

# Resend SMTP contact form settings
RESEND_API_KEY=
RESEND_SMTP_PORT=465
CONTACT_RECEIVER_EMAIL=elitecourtspadel@gmail.com
CONTACT_SENDER_EMAIL="Elite Courts <noreply@elitecourts.com.pk>"

# Optional generic SMTP fallback if Resend is not used
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Optional Google reviews integration
# Keep these server-side only. Do not expose them with NEXT_PUBLIC_ prefixes.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
